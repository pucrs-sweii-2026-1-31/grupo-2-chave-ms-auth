{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./.github/hooks/scripts/log-prompt-hook.sh",
        "powershell": "bash ./.github/hooks/scripts/log-prompt-hook.sh",
        "timeoutSec": 10,
        "cwd": "${workspaceFolder}"
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "bash": "./.github/hooks/scripts/log-prompt-hook.sh",
        "powershell": "bash ./.github/hooks/scripts/log-prompt-hook.sh",
        "timeoutSec": 10,
        "cwd": "${workspaceFolder}"
      }
    ]
  }
}
