{
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "ai-prompt-auto-log",
            "type": "command",
            "command": "PROMPT_LOG_SOURCE=gemini bash $GEMINI_PROJECT_DIR/.ai_log/log_gemini.sh"
          }
        ]
      }
    ]
  }
}
